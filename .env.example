# Copy this file to `.env` and fill in your Supabase project values.
# Project dashboard → Settings → API.
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Optional — Open-Meteo is free and key-less; only override to proxy it.
# EXPO_PUBLIC_WEATHER_API_BASE=https://api.open-meteo.com/v1
# EXPO_PUBLIC_GEOCODING_API_BASE=https://geocoding-api.open-meteo.com/v1
